# Cloud API environment variables (copy to .env and fill in values)
# Never commit .env to git.

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-random-secret

# Server-to-server sync key — same command as above, use a different value
CLOUD_SYNC_KEY=change-me-to-a-random-sync-key

# Path to the cloud SQLite database (set by render.yaml; override for local dev)
DATABASE_PATH=/data/petlab.db

# Lab identifier (must match lab_id in on-prem config.json)
LAB_ID=petlabs-pretoria

# Gauge-photo OCR. Cloud uses Gemini — get a free key at https://aistudio.google.com/app/apikey
# On-prem installs can instead set GAUGE_OLLAMA_MODEL (e.g. qwen2.5vl:7b) + OLLAMA_HOST.
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.0-flash

# --- Security hardening knobs ---

# CORS: comma-separated browser origins allowed to call the API. Native mobile apps
# need nothing here. Defaults to localhost dev origins; never the '*' wildcard.
CORS_ALLOW_ORIGINS=

# Max request body size in bytes (default 25 MiB) — bounds the photo/EUR/CSV DoS surface.
MAX_REQUEST_BYTES=26214400

# Max EUR-form photos accepted per /api/gauges/eur-photos request (default 20).
MAX_EUR_PHOTOS=20

# Keyed HMAC for ML model artifacts. When set, trained models are signed so an attacker
# who can only write the model directory cannot forge a valid model. Generate like API_SECRET_KEY.
MODEL_HMAC_KEY=

# Set to 1 to refuse legacy unsigned models entirely (do this after re-training with
# MODEL_HMAC_KEY so every model carries an HMAC).
MODEL_REQUIRE_SIGNED=
