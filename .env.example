# Cloud API environment variables (copy to .env and fill in values)
# Never commit .env to git.

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-random-secret

# Server-to-server sync key — same command as above, use a different value
CLOUD_SYNC_KEY=change-me-to-a-random-sync-key

# Path to the cloud SQLite database (set by render.yaml; override for local dev)
DATABASE_PATH=/data/petlab.db

# Lab identifier (must match lab_id in on-prem config.json)
LAB_ID=petlabs-pretoria
