    "@testing-library/react-native": "^14.0.1",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.3.0"
  }
