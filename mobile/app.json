{
  "expo": {
    "name": "PetBMS",
    "slug": "petlab-monitor",
    "version": "1.0.0",
    "scheme": "petlab",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0056A7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petlabs.monitor",
      "infoPlist": {
        "NSCameraUsageDescription": "PetBMS uses the camera to photograph gauges and log readings.",
        "NSPhotoLibraryUsageDescription": "PetBMS can access photos to select gauge images for logging."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0056A7"
      },
      "package": "com.petlabs.monitor",
      "permissions": ["android.permission.CAMERA"],
      "allowBackup": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PetBMS to access your photos.",
          "cameraPermission": "Allow PetBMS to use the camera to log gauge readings."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1863DC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
