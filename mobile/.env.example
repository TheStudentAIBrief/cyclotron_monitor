# Copy to .env and set your API URL, or use start_dev.ps1 (repo root) which
# auto-detects your WiFi IP and writes this file for you.
#
# Same-network dev (laptop + phone on same WiFi):
EXPO_PUBLIC_API_URL=http://192.168.1.X:8000
